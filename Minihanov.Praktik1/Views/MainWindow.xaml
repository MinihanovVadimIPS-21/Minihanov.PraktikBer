<Window x:Class="Minihanov.Praktik1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задачи" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Задачи" FontSize="28" FontWeight="Light" Foreground="#2C3E50"/>
            <TextBlock x:Name="txtDateTime" Text="" FontSize="14" Foreground="#95A5A6" 
                       VerticalAlignment="Bottom" Margin="20,0,0,8"/>
        </StackPanel>
        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <Button x:Name="btnAdd" Content=" Добавить" Background="Transparent" 
                    Foreground="#3498DB" BorderThickness="0" Padding="8,4" 
                    FontSize="14" Cursor="Hand" Click="btnAdd_Click"/>
            <Button x:Name="btnEdit" Content=" Изменить" Background="Transparent" 
                    Foreground="#3498DB" BorderThickness="0" Padding="8,4" 
                    FontSize="14" Cursor="Hand" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content=" Удалить" Background="Transparent" 
                    Foreground="#E74C3C" BorderThickness="0" Padding="8,4" 
                    FontSize="14" Cursor="Hand" Click="btnDelete_Click"/>
            <Button x:Name="btnImportant" Content=" Важная" Background="Transparent" 
                    Foreground="#F39C12" BorderThickness="0" Padding="8,4" 
                    FontSize="14" Cursor="Hand" Click="btnImportant_Click"/>
            <Button x:Name="btnSave" Content="Сохранить" Background="Transparent" 
                    Foreground="#000000" BorderThickness="0" Padding="8,4" 
                    FontSize="16" Cursor="Hand" Click="btnSave_Click" ToolTip="Сохранить"/>
            <Button x:Name="btnLoad" Content="Загрузить" Background="Transparent" 
                    Foreground="#000000" BorderThickness="0" Padding="8,4" 
                    FontSize="16" Cursor="Hand" Click="btnLoad_Click" ToolTip="Загрузить"/>
        </WrapPanel>
        <WrapPanel Grid.Row="2" Margin="0,0,0,12">
            <ComboBox x:Name="cmbStatusFilter" Width="120" Background="White" 
                      BorderBrush="#E0E0E0" FontSize="13" Height="30"
                      SelectionChanged="cmbStatusFilter_SelectionChanged">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="Новая"/>
                <ComboBoxItem Content="В процессе"/>
                <ComboBoxItem Content="Завершена"/>
            </ComboBox>
            <ComboBox x:Name="cmbSort" Width="140" Background="White" 
                      BorderBrush="#E0E0E0" FontSize="13" Height="30" Margin="8,0,0,0"
                      SelectionChanged="cmbSort_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="По приоритету"/>
                <ComboBoxItem Content="По сроку"/>
            </ComboBox>
            <TextBox x:Name="txtSearch" Width="180" Background="White" 
                     BorderBrush="#E0E0E0" FontSize="13" Height="30" Margin="8,0,0,0"
                     TextChanged="txtSearch_TextChanged"/>
            <Button x:Name="btnClearSearch" Content="" Background="Transparent" 
                    BorderThickness="0" Width="30" Height="30" Click="btnClearSearch_Click" 
                    Cursor="Hand" FontSize="12" Foreground="#95A5A6"/>
        </WrapPanel>
        <ListBox Grid.Row="3" x:Name="lstTasks" Background="Transparent" 
                 BorderThickness="0" SelectionChanged="lstTasks_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" BorderBrush="#ECF0F1" BorderThickness="0,0,0,1" 
                            Padding="12,8" Margin="0,0,0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="" Foreground="#F39C12" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       Visibility="{Binding IsImportant}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsImportant}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsImportant}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" 
                                           Foreground="#2C3E50"/>
                                <TextBlock Text="{Binding Description}" FontSize="13" 
                                           Foreground="#7F8C8D" Margin="0,2,0,4"/>
                                <WrapPanel>
                                    <TextBlock Text="{Binding Status}" FontSize="11" 
                                               Foreground="#3498DB" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding Priority}" FontSize="11" 
                                               Foreground="#95A5A6" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding DueDate, StringFormat=dd.MM.yyyy}" 
                                               FontSize="11" Foreground="#95A5A6"/>
                                    <TextBlock Text="⚠ Просрочена" FontSize="11" Foreground="#E74C3C"
                                               Margin="12,0,0,0">
                                        <TextBlock.Visibility>
                                            <Binding Path="IsOverdue">
                                                <Binding.Converter>
                                                    <BooleanToVisibilityConverter/>
                                                </Binding.Converter>
                                            </Binding>
                                        </TextBlock.Visibility>
                                    </TextBlock>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Border Grid.Row="4" Margin="0,12,0,0" Padding="12,8" Background="#F8F9FA">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtStats" Text="" FontSize="13" Foreground="#7F8C8D"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>