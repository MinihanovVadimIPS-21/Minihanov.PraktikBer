<Window x:Class="Minihanov.Praktik1.AddEditTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Добавление/Редактирование задачи" Height="450" Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Детали задачи" FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtTitle" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Описание:" VerticalAlignment="Top" Margin="5,10,5,0"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtDescription" Margin="5" Height="60" 
                 TextWrapping="Wrap" AcceptsReturn="True"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Приоритет:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbPriority" Margin="5" Height="30">
            <ComboBoxItem Content="Низкий"/>
            <ComboBoxItem Content="Средний" IsSelected="True"/>
            <ComboBoxItem Content="Высокий"/>
            <ComboBoxItem Content="Критический"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Срок выполнения:" VerticalAlignment="Center" Margin="5"/>
        <DatePicker Grid.Row="4" Grid.Column="1" x:Name="dpDueDate" Margin="5" Height="30" 
                    SelectedDate="{x:Static sys:DateTime.Now}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="5" Grid.Column="1" x:Name="cmbStatus" Margin="5" Height="30">
            <ComboBoxItem Content="Новая" IsSelected="True"/>
            <ComboBoxItem Content="В процессе"/>
            <ComboBoxItem Content="Завершена"/>
        </ComboBox>

        <CheckBox Grid.Row="6" Grid.Column="1" x:Name="chkImportant" Content="⭐ Важная задача" 
                  Margin="5" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnOk" Content="OK" Width="80" Height="30" Click="btnOk_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="80" Height="30" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>